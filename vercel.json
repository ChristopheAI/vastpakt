{
  "redirects": [
    { "source": "/offerte-opvolging", "destination": "/voor-wie", "permanent": true },
    { "source": "/offerte-opvolging/:path*", "destination": "/voor-wie", "permanent": true },
    { "source": "/facturatie-bewijs", "destination": "/voor-wie", "permanent": true },
    { "source": "/facturatie-bewijs/:path*", "destination": "/voor-wie", "permanent": true },
    { "source": "/dubbel-werk", "destination": "/voor-wie", "permanent": true },
    { "source": "/dubbel-werk/:path*", "destination": "/voor-wie", "permanent": true },
    { "source": "/over-vastpakt", "destination": "/over-mij", "permanent": true },
    { "source": "/over-vastpakt/:path*", "destination": "/over-mij", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
